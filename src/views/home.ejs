<%- include('partials/header') %>
<main>
  <h1><%= title %></h1>
  <p>
    This site is a <strong>campus IT help desk</strong> demo. Students and faculty can open support
    tickets, track status, and add comments. Staff and administrators manage the queue and ticket
    categories.
  </p>
  <% if (typeof isLoggedIn !== 'undefined' && isLoggedIn) { %>
  <p><a href="/tickets">Go to your tickets</a> <a href="/account">Account</a></p>
  <% } else { %>
  <p><a href="/register">Create an account</a> or <a href="/login">sign in</a> to submit a ticket.</p>
  <% } %>
  <p><a href="/services">What we support</a> <a href="/about">About</a></p>
</main>
<%- include('partials/footer') %>
