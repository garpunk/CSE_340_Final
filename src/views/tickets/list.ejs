<%- include('../partials/header') %>
<main class="ticket-page">
  <h1><%= title %></h1>
  <p>
    <% if (staffView) { %>
      All tickets (staff view).
    <% } else { %>
      Your submitted tickets.
    <% } %>
  </p>
  <p class="actions">
    <a href="/tickets/new">New ticket</a>
    <a href="/">Home</a>
  </p>
  <% if (!tickets || tickets.length === 0) { %>
    <p>No tickets yet.</p>
  <% } else { %>
    <div class="table-scroll">
    <table class="ticket-table">
      <thead>
        <tr>
          <th>ID</th>
          <th>Title</th>
          <th>Category</th>
          <th>Status</th>
          <th>Updated</th>
          <% if (staffView) { %>
          <th>User</th>
          <% } %>
        </tr>
      </thead>
      <tbody>
        <% tickets.forEach(function (t) { %>
        <tr>
          <td><%= t.id %></td>
          <td><a href="/tickets/<%= t.id %>"><%= t.title %></a></td>
          <td><%= t.category_name %></td>
          <td><span class="status-badge"><%= t.status %></span></td>
          <td><%= new Date(t.updated_at).toLocaleString() %></td>
          <% if (staffView) { %>
          <td><%= t.user_name %></td>
          <% } %>
        </tr>
        <% }); %>
      </tbody>
    </table>
    </div>
  <% } %>
</main>
<%- include('../partials/footer') %>
