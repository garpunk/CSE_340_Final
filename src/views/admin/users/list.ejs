<%- include('../../partials/header') %>
<main class="ticket-page">
  <h1><%= title %></h1>
  <p>Directory of all accounts. You can change another user’s role below; you cannot change your own while signed in.</p>
  <p class="actions">
    <a href="/admin/categories">Categories</a>
    <a href="/admin-area">Admin area</a>
    <a href="/">Home</a>
  </p>
  <% if (!users || users.length === 0) { %>
    <p>No users found.</p>
  <% } else { %>
    <div class="table-scroll">
    <table class="ticket-table">
      <thead>
        <tr>
          <th>ID</th>
          <th>Name</th>
          <th>Email</th>
          <th>Role</th>
          <th>Created</th>
          <th>Set role</th>
        </tr>
      </thead>
      <tbody>
        <% users.forEach(function (u) { %>
        <tr>
          <td><%= u.id %></td>
          <td><%= u.name %></td>
          <td><%= u.email %></td>
          <td><span class="status-badge"><%= u.role %></span></td>
          <td><%= new Date(u.created_at).toLocaleString() %></td>
          <td>
            <% if (typeof user !== 'undefined' && user && String(u.id) === String(user.id)) { %>
            <em>—</em>
            <% } else { %>
            <form method="post" action="/admin/users/<%= u.id %>/role" class="admin-role-form">
              <select name="role" aria-label="New role">
                <option value="user" <%= u.role === 'user' ? 'selected' : '' %>>user</option>
                <option value="staff" <%= u.role === 'staff' ? 'selected' : '' %>>staff</option>
                <option value="admin" <%= u.role === 'admin' ? 'selected' : '' %>>admin</option>
              </select>
              <button type="submit">Update</button>
            </form>
            <% } %>
          </td>
        </tr>
        <% }); %>
      </tbody>
    </table>
    </div>
  <% } %>
</main>
<%- include('../../partials/footer') %>
